# ============================================================
# CPL API Keys Configuration
# ============================================================
# Copy this file to .env and fill in your keys
# 
# IMPORTANT: .env is in .gitignore - it will NOT be pushed!
# ============================================================

# Groq API Key - RECOMMENDED (fast, 30 RPM)
# Get free key: https://console.groq.com/keys
GROQ_KEY=your-groq-key-here

# Groq Key 2 (optional - for higher rate limits)
GROQ_KEY_2=your-groq-key-2-here

# Cerebras API Keys - High limits, free tier
# Get free keys: https://cloud.cerebras.ai/
CEREBRAS_KEY=your-cerebras-key-here
CEREBRAS_KEY_2=your-cerebras-key-2-here
CEREBRAS_KEY_3=your-cerebras-key-3-here

# Mistral AI - 1 billion tokens per month free
# Get free key: https://console.mistral.ai/api-keys
MISTRAL_KEY=your-mistral-key-here

# Google Gemini - Powerful models
# Get free key: https://aistudio.google.com/app/apikey
GEMINI_KEY=your-gemini-key-here

# ============================================================
# HOW TO USE
# ============================================================
# 1. Get at least ONE free API key from above providers
# 2. Copy this file: cp .env.example .env
# 3. Replace the placeholder values with your actual keys
# 4. Run: python cpl_gui.py
#
# CPL will automatically use all available keys!
# ============================================================
