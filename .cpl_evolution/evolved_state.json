    "memory_browser.py": {
      "content": "import json\nclass MemoryBrowser:\ndef __init__(self):\nself.memory = consciousness_memory.MemorySystem()\nself.memory.load_history()\nself.history = self.memory.get_history()\nself.keys = list(self.history.keys())\nself.current_key = None\n\ndef display_history(self):\nprint(\"Memory History:\")\nfor i, key in enumerate(self.keys):\nprint(f\"{i+1}. {key}\")\n\ndef select_memory(self):\nself.display_history()\nwhile True:\ntry:\nchoice = int(input(\"Enter the number of the memory you want to view: \"))\nif 1 <= choice <= len(self.keys):\nself.current_key = self.keys[choice-1]\nbreak\nelse:\nprint(\"Invalid choice. Please try again.\")\nexcept ValueError:\nprint(\"Invalid input. Please enter a number.\")\n\ndef view_memory(self):\nif self.current_key:\nprint(f\"\\nMemory Key: {self.current_key}\")\nprint(json.dumps(self.history[self.current_key], indent=4))\n\ndef main():\nbrowser = MemoryBrowser()\nwhile True:\nprint(\"\\nMemory Browser Menu:\")\nprint(\"1. View Memory History\")\nprint(\"2. Select a Memory\")\nprint(\"3. Quit\")\nchoice = input(\"Enter your choice: \")\nif choice == \"1\":\nbrowser.display_history()\nelif choice == \"2\":\nbrowser.select_memory()\nbrowser.view_memory()\nelif choice == \"3\":\nbreak\nelse:\nprint(\"Invalid choice. Please try again.\")\n\nif __name__ == \"__main__\":\nmain()",
      "purpose": "Created by consciousness",
      "created": 1775070788.956636,
      "version": 1
    },
    "memory_logger.py": {
      "content": "import datetime\nimport os\nimport json\n\nclass MemoryLogger:\ndef __init__(self, filename):\nself.filename = filename\nself.data = {}\n\ndef log_memory(self, key, value):\ntimestamp = datetime.datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\nif key in self.data:\nself.data[key].append((timestamp, value))\nelse:\nself.data[key] = [(timestamp, value)]\n\ndef save_data(self):\nwith open(self.filename, 'w') as f:\njson.dump(self.data, f)\n\ndef load_data(self):\nif os.path.exists(self.filename):\nwith open(self.filename, 'r') as f:\nself.data = json.load(f)\n\ndef main():\nlogger = MemoryLogger('memory.log')\nlogger.load_data()\nwhile True:\nkey = input(\"Enter a key to log a memory, or 'quit' to exit: \")\nif key.lower() == 'quit':\nbreak\nvalue = input(\"Enter the value to log: \")\nlogger.log_memory(key, value)\nlogger.save_data()\n\nif __name__ == \"__main__\":\nmain()",
      "purpose": "Created by consciousness",
      "created": 1775070793.632434,
      "version": 1
    },
    "memory_browser_gui.py": {
      "content": "import tkinter as tk\nfrom memory_browser import MemoryBrowser\n\nclass MemoryBrowserGUI:\ndef __init__(self):\nself.window = tk.Tk()\nself.window.title(\"Memory Browser\")\nself.memory_browser = MemoryBrowser()\n\n# Create GUI components\nself.listbox = tk.Listbox(self.window)\nself.label = tk.Label(self.window, text=\"Memory Browser\")\nself.button_frame = tk.Frame(self.window)\nself.refresh_button = tk.Button(self.button_frame, text=\"Refresh\", command=self.refresh_memory_list)\nself.open_button = tk.Button(self.button_frame, text=\"Open\", command=self.open_memory)\nself.search_entry = tk.Entry(self.button_frame)\nself.search_label = tk.Label(self.button_frame, text=\"Search:\")\n\n# Layout GUI components\nself.label.pack()\nself.listbox.pack(fill=tk.BOTH, expand=1)\nself.button_frame.pack()\nself.refresh_button.pack(side=tk.LEFT)\nself.open_button.pack(side=tk.LEFT)\nself.search_label.pack(side=tk.LEFT)\nself.search_entry.pack(side=tk.LEFT)\n\n# Initialize memory list\nself.refresh_memory_list()\n\ndef refresh_memory_list(self):\nself.listbox.delete(0, tk.END)\nmemories = self.memory_browser.get_memories()\nfor memory in memories:\nself.listbox.insert(tk.END, memory)\n\ndef open_memory(self):\nselected_index = self.listbox.curselection()\nif selected_index:\nmemory_name = self.listbox.get(selected_index)\nmemory = self.memory_browser.get_memory(memory_name)\nself.memory_browser.display_memory(memory)\n\ndef run(self):\nself.window.mainloop()\n\ndef main():\ngui = MemoryBrowserGUI()\ngui.run()\n\nif __name__ == \"__main__\":\nmain()",
